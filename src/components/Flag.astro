---
import type { Locale } from "@/i18n";

export interface Props {
  name: Locale;
}

// Flag icons from https://icon-sets.iconify.design/flagpack/
const { name } = Astro.props;

// BASE_URL may be "/" or "/general-intelligence-assessment" (no trailing slash
// under GitHub Pages). Strip any trailing slash before joining so flags resolve
// correctly regardless of base.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const flagUrl = `${base}/flags/${name}.svg`;
---

<span
  class="inline-block aspect-[4/3] w-8 bg-contain bg-center bg-no-repeat"
  style={{ backgroundImage: `url('${flagUrl}')` }}></span>
