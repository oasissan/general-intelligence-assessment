---
import type { Locale } from "@/i18n";

export interface Props {
  name: Locale;
}

// Flag icons from https://icon-sets.iconify.design/flagpack/
const { name } = Astro.props;
---

<span
  class="inline-block aspect-[4/3] w-8 bg-contain bg-center bg-no-repeat"
  style={{ backgroundImage: `url('/flags/${name}.svg')` }}></span>
