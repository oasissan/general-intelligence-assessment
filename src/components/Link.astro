---
import { cn } from "@/lib/utils";
import type { ClassValue } from "clsx";

interface Props {
  href: string;
  targetBlank?: boolean;
  noreferrer?: boolean;
  class?: ClassValue;
}

const { href, targetBlank, noreferrer, class: className } = Astro.props;

const rel = targetBlank
  ? noreferrer
    ? "noopener noreferrer"
    : "noopener"
  : undefined;

const target = targetBlank ? "_blank" : undefined;
---

<a {href} {rel} {target} class={cn("font-semibold hover:underline", className)}
  ><slot /></a
>
