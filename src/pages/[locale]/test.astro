---
import { bakeLocaleTranslations, LOCALES } from "@/i18n";
import TestApp from "@components/TestApp/TestApp";
import Layout from "@layouts/Layout.astro";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (() => {
  return LOCALES.map((locale) => ({ params: { locale } }));
}) satisfies GetStaticPaths;

const { locale } = Astro.params;
const translations = bakeLocaleTranslations(locale);
---

<Layout subtitle="Test">
  <TestApp client:load translations={translations} />
</Layout>
